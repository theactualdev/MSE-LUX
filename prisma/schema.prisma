// MSE Lux database schema.
//
// Prisma 7: the connection URL lives in `prisma.config.ts` (CLI/migrations) and is
// passed to the runtime client in `src/lib/db.ts` — the datasource block below only
// declares the provider. Money is always stored as integer minor units in the two
// admin-authored currencies (NGN, USD); never floats, never FX-derived values.
//
// --- Hand-maintained SQL constraints ---
//
// Three constraints below cannot be expressed in Prisma's schema language and only exist
// as hand-edited SQL in the migrations named. Prisma is blind to all three, so a future
// `prisma migrate dev` will diff them away and emit a `DROP` for each — that generated
// migration must be inspected and stripped of the drop before being applied. See the
// comments on the fields below for details:
//   1. `Address_one_default_per_profile` — partial unique index, above `Address.isDefault`,
//      hand-added in `prisma/migrations/20260719013937_init/migration.sql`.
//   2. `CartItem_cartId_productId_variantId_key` with `NULLS NOT DISTINCT` — above
//      `CartItem`'s `@@unique([cartId, productId, variantId])`, hand-added in
//      `prisma/migrations/20260719013937_init/migration.sql`.
//   3. `Profile_id_fkey` — cross-schema cascade FK from `Profile.id` to `auth.users(id)`,
//      above `Profile.id`, hand-added in
//      `prisma/migrations/20260721215213_fix_profile_provisioning/migration.sql`.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Catalog ---

enum ProductStatus {
  ACTIVE
  DRAFT
}

enum Badge {
  NEW
  BEST_SELLER
}

model Category {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  description   String?
  image         String?
  subcategories Subcategory[]
  products      Product[]
}

model Subcategory {
  id         String    @id @default(cuid())
  slug       String
  name       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([categoryId, slug])
}

model Product {
  id               String        @id @default(cuid())
  slug             String        @unique
  sku              String        @unique
  name             String
  shortDescription String
  description      String
  material         String
  materialTags     String[]
  badges           Badge[]
  status           ProductStatus @default(ACTIVE)

  // Money is always integer minor units in both authored currencies; never floats.
  priceNgnMinor     Int
  priceUsdMinor     Int
  salePriceNgnMinor Int?
  salePriceUsdMinor Int?

  // Inventory for products without variants; variant products track inventory on ProductVariant instead.
  inventory Int @default(0)

  // Optional per-product SEO overrides; the PDP falls back to name/shortDescription when null.
  seoTitle       String?
  seoDescription String?

  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id])
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  images        ProductImage[]
  variants      ProductVariant[]
  optionTypes   ProductOptionType[]
  collections   ProductCollection[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orderLines    OrderLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, status])
  @@index([subcategoryId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String  @unique
  inventory Int     @default(0)

  // Nullable overrides: null means "inherit the product's price".
  priceNgnMinor Int?
  priceUsdMinor Int?

  image      String?
  options    VariantOption[]
  cartItems  CartItem[]
  orderLines OrderLine[]

  @@index([productId])
}

// Authored, ordered option types/values for a product (e.g. Size: S|M|L|XL,
// Color: Turquoise|Coral|Ivory), matching `optionTypes: { name, values[] }[]`
// in `src/types/catalog.ts`. `position` preserves authoring order, and a value
// can exist here even if no variant currently uses it. Distinct from
// `VariantOption`, which records the option values a specific variant *is*.
model ProductOptionType {
  id        String               @id @default(cuid())
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  position  Int
  values    ProductOptionValue[]

  @@unique([productId, name])
  @@unique([productId, position])
  @@index([productId])
}

model ProductOptionValue {
  id           String            @id @default(cuid())
  optionTypeId String
  optionType   ProductOptionType @relation(fields: [optionTypeId], references: [id], onDelete: Cascade)
  value        String
  position     Int

  @@unique([optionTypeId, value])
  @@unique([optionTypeId, position])
  @@index([optionTypeId])
}

model VariantOption {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  name      String
  value     String

  @@unique([variantId, name])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  src       String
  alt       String
  position  Int

  @@unique([productId, position])
}

model Collection {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  image       String?
  products    ProductCollection[]
}

model ProductCollection {
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  position     Int?

  @@id([productId, collectionId])
  @@index([collectionId])
}

// --- Identity ---

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

model Profile {
  // This id is the Supabase `auth.users.id` (UUID) — it is supplied by Supabase Auth,
  // never generated here. Do NOT add a password/credential column to this model;
  // all credential handling is owned by Supabase Auth.
  //
  // HAND-ADDED CONSTRAINT — invisible to Prisma, lives only in SQL:
  // `prisma/migrations/20260721215213_fix_profile_provisioning/migration.sql` hand-adds a foreign
  // key, `Profile_id_fkey FOREIGN KEY (id) REFERENCES auth.users(id) ON DELETE CASCADE`, so
  // deleting a Supabase auth user cascades to delete its Profile row instead of orphaning it.
  // Prisma cannot model a cross-schema FK into the unmanaged `auth` schema (Supabase's GoTrue
  // owns it, not these migrations), so it has no representation here and will never appear in
  // a Prisma-generated migration diff. Before applying any future `prisma migrate dev` output,
  // inspect it for a DROP of this constraint and remove that line — Prisma will otherwise
  // conclude the FK is unmanaged/extraneous and drop it.
  id    String  @id @db.Uuid
  // Not unique: it mirrors `auth.users.email`, which Supabase Auth already keeps unique, and
  // a Profile-level unique index is what caused re-signup with a stale email to silently fail
  // to provision a row (see the fix-profile-provisioning migration). Email is read-only in the
  // app — always set by the `auth_hooks.handle_new_user()` trigger, never by client writes.
  email String
  name  String?
  phone String?
  role  Role    @default(CUSTOMER)

  addresses Address[]
  carts     Cart[]
  wishlists Wishlist[]
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id        String  @id @default(cuid())
  profileId String  @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  country    String
  postalCode String?

  // HAND-ADDED CONSTRAINT — invisible to Prisma, lives only in SQL:
  // `prisma/migrations/20260719013937_init/migration.sql` hand-adds a partial unique index,
  // `Address_one_default_per_profile ON "Address"("profileId") WHERE "isDefault"`, enforcing
  // at most one default address per profile at the DB layer (spec §3.3/§7's safety net behind
  // the application-level single-default invariant). Prisma's schema language cannot express
  // partial unique indexes, so it has no representation here and will never appear in a
  // Prisma-generated migration diff. Before applying any future `prisma migrate dev` output,
  // inspect it for `DROP INDEX "Address_one_default_per_profile"` and remove that line — Prisma
  // will otherwise conclude the index is unmanaged/extraneous and drop it.
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

// --- Cart & wishlist ---

model Cart {
  id        String   @id @default(cuid())
  profileId String?  @db.Uuid
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  quantity Int

  // HAND-ADDED CONSTRAINT — invisible to Prisma, lives only in SQL:
  // `prisma/migrations/20260719013937_init/migration.sql` hand-adds `NULLS NOT DISTINCT` to the
  // unique index generated for this `@@unique`. Postgres normally treats NULLs as distinct in
  // unique indexes, so without this clause a variantless product (`variantId = null`) could be
  // added to the same cart an unbounded number of times as separate rows. Prisma's schema
  // language cannot express `NULLS NOT DISTINCT`, so it has no representation here and a future
  // `prisma migrate dev` will silently regenerate this index WITHOUT it. Before applying any
  // generated migration, inspect it for a plain `DROP INDEX "CartItem_cartId_productId_variantId_key"`
  // followed by a re-create missing `NULLS NOT DISTINCT`, and fix it up to preserve the clause.
  @@unique([cartId, productId, variantId])
}

model Wishlist {
  id        String   @id @default(cuid())
  profileId String?  @db.Uuid
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  items WishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
}

// --- Orders ---
//
// Orders are snapshot-based: nothing here is a live join. Shipping address and
// line-item details are copied at the moment the order is placed so that later
// edits or deletions to Profile/Address/Product/ProductVariant can never alter
// or erase order history. Deleting a customer or a product must only null out
// the (nullable, analytics-only) FK — never cascade into Order/OrderLine.

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  profileId   String?     @db.Uuid
  profile     Profile?    @relation(fields: [profileId], references: [id], onDelete: SetNull)
  email       String
  status      OrderStatus @default(PENDING)
  // The canonical business-event timestamp ("when the order was placed"); the
  // app queries/sorts orders by this column. `createdAt` below is the row's
  // audit timestamp and is not the same thing, even though both default to now().
  placedAt    DateTime    @default(now())

  // Shipping address snapshot — copied at order placement, NOT a foreign key to
  // Address, so later edits/deletion of the customer's saved address never
  // changes historical orders.
  shipFullName   String
  shipPhone      String
  shipLine1      String
  shipLine2      String?
  shipCity       String
  shipState      String
  shipCountry    String
  shipPostalCode String?

  shippingLabel String

  // Money is always integer minor units; never floats. Totals are stored in
  // `currency`'s minor units.
  currency      String @default("NGN")
  subtotalMinor Int
  shippingMinor Int
  taxMinor      Int
  totalMinor    Int

  lines OrderLine[]

  // Row-audit timestamp (when this record was created/last touched), distinct
  // from `placedAt`, the business event timestamp.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, placedAt])
  @@index([status])
}

model OrderLine {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Denormalized product data, copied at order placement so the line survives
  // catalog changes verbatim.
  productName  String
  variantLabel String?
  // Snapshot columns: `image`/`imageAlt` are copied at order placement, not a
  // live join to ProductImage, so alt text survives catalog changes verbatim.
  image        String?
  imageAlt     String?
  quantity     Int

  unitPriceMinor Int
  lineTotalMinor Int

  // Nullable, analytics-only references. Deleting the product/variant must
  // only null these out — never cascade — leaving the snapshot above intact.
  productId String?
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}
